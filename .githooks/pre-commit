#!/usr/bin/env bash
# kaelen/skills 提交前门禁：跑 bin/check.sh，不过就拦下提交。
# 启用：git config core.hooksPath .githooks  （或跑 bin/setup-hooks.sh）
set -uo pipefail
root="$(git rev-parse --show-toplevel)"
cd "$root" || exit 1

if [ ! -x bin/check.sh ]; then
  echo "pre-commit: 找不到可执行的 bin/check.sh，跳过门禁" >&2
  exit 0
fi

if bin/check.sh; then
  exit 0
else
  echo >&2
  echo "pre-commit 被拦下：bin/check.sh 未通过，修好上面的问题再提交。" >&2
  echo "确需跳过：git commit --no-verify" >&2
  exit 1
fi
