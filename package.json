{
  "name": "kaelen-skills",
  "version": "1.1.0",
  "private": true,
  "description": "零基建、纯 prompt 技能包的仓库工具链（markdown 校验与提交前格式化）。",
  "scripts": {
    "prepare": "husky",
    "check": "bash bin/check.sh",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "test": "npm run check && npm run lint:md"
  },
  "lint-staged": {
    "*.md": "markdownlint-cli2 --fix"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "markdownlint-cli2": "^0.22.1"
  }
}
